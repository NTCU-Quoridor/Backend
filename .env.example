# Cloudflase 金鑰
TURNSTILE_SECRET=1x0000000000000000000000000000000AA  # 平台提供的測試金鑰

# JWT 協定
SECRET_KEY=your-super-secret-key-change-this-in-production
FRONTEND_URL=http://localhost:5173/

# Gmail SMTP 設定 (可使用 Mailtrap 的 sandbox)
MAIL_USERNAME=你的 username
MAIL_PASSWORD=你的 password
MAIL_SERVER=sandbox.smtp.mailtrap.io  # 若使用其他方式建立需修改
MAIL_PORT=2525  # 可根據提供的 Port 選擇
MAIL_FROM=support@wallgo.com  # 可自行設定
MAIL_STARTTLS=True
MAIL_SSL_TLS=False